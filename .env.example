NODE_ENV=development
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
DATABASE_URL=postgresql://crm:crm@localhost:5432/crm?schema=public
REDIS_URL=redis://localhost:6379

# Session secret — change to a random value in production
SESSION_SECRET=orbit-inbox-dev-session-secret-change-in-production

# Development authentication. Replace with production OIDC/session auth.
DEV_TENANT_ID=11111111-1111-4111-8111-111111111111
DEV_USER_ID=22222222-2222-4222-8222-222222222222

# Seed password for demo users (sahil@example.com / ananya@example.com)
SEED_PASSWORD=orbit123

# 32-byte base64 value. Use Google Cloud KMS in production.
TOKEN_ENCRYPTION_KEY=zpSqXqI5V8fC0hWaPqXpVhY2b0c4e6g8iAqC0eI2g4Y=

# Google / Gmail
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/v1/connections/gmail/callback
GOOGLE_PUBSUB_AUDIENCE=http://localhost:4000/v1/webhooks/gmail
GOOGLE_PUBSUB_TOPIC=projects/your-project/topics/gmail
GOOGLE_PUBSUB_SERVICE_ACCOUNT_EMAIL=

# Meta / WhatsApp / Instagram / Messenger
META_APP_ID=
META_APP_SECRET=
META_GRAPH_VERSION=v25.0
META_REDIRECT_URI=http://localhost:4000/v1/connections/meta/callback
META_WEBHOOK_VERIFY_TOKEN=

# Optional Google Cloud deployment
GCP_PROJECT_ID=
GCS_BUCKET=
KMS_KEY_NAME=
