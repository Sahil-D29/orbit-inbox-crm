{
  "name": "unified-inbox-crm",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @crm/api --filter @crm/web --filter @crm/worker dev",
    "build": "pnpm --filter @crm/contracts build && pnpm --filter @crm/database generate && pnpm --filter @crm/database build && pnpm -r --filter !@crm/contracts --filter !@crm/database build",
    "start": "pnpm --parallel --filter @crm/api --filter @crm/web start",
    "typecheck": "pnpm --filter @crm/contracts build && pnpm --filter @crm/database build && pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @crm/database generate",
    "db:push": "pnpm --filter @crm/database push",
    "db:migrate": "pnpm --filter @crm/database migrate",
    "db:seed": "pnpm --filter @crm/database seed",
    "db:studio": "pnpm --filter @crm/database studio"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "prettier": "3.7.4",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "allowBuilds": {
      "@nestjs/core": true,
      "@prisma/client": true,
      "@prisma/engines": true,
      "esbuild": true,
      "msgpackr-extract": true,
      "prisma": true,
      "sharp": true,
      "unrs-resolver": true
    }
  }
}
