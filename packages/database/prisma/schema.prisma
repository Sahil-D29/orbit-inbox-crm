generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  AGENT
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum Availability {
  ONLINE
  AWAY
  OFFLINE
}

enum Provider {
  GMAIL
  WHATSAPP
  INSTAGRAM_DM
  INSTAGRAM_COMMENTS
  FACEBOOK_MESSENGER
}

enum ConnectionStatus {
  PENDING
  CONNECTED
  DEGRADED
  DISCONNECTED
}

enum ConversationStatus {
  OPEN
  PENDING
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum DeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum CommentStatus {
  OPEN
  HIDDEN
  RESOLVED
}

enum JobStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
}

enum MergeStatus {
  SUGGESTED
  CONFIRMED
  REJECTED
  UNDONE
}

model Tenant {
  id              String              @id @default(uuid()) @db.Uuid
  name            String
  slug            String              @unique
  retentionDays   Int                 @default(365)
  timezone        String              @default("Asia/Calcutta")
  businessHours   Json                @default("{\"days\":[1,2,3,4,5],\"start\":\"09:00\",\"end\":\"18:00\"}")
  firstResponseSlaMinutes Int          @default(60)
  resolutionSlaMinutes    Int          @default(1440)
  assignmentMode          String       @default("MANUAL")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  memberships     Membership[]
  connections     ChannelConnection[]
  contacts        Contact[]
  identities      ExternalIdentity[]
  conversations   Conversation[]
  messages        Message[]
  attachments     Attachment[]
  instagramPosts  InstagramPost[]
  comments        InstagramComment[]
  labels          Label[]
  notes           Note[]
  savedViews      SavedView[]
  syncCursors     SyncCursor[]
  webhookEvents   WebhookEvent[]
  outboundJobs    OutboundJob[]
  auditLogs       AuditLog[]
  mergeOperations ContactMerge[]
  conversationLabels ConversationLabel[]
  contactLabels      ContactLabel[]
}

model User {
  id          String       @id @default(uuid()) @db.Uuid
  email       String       @unique
  name        String
  avatarUrl   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberships Membership[]
  assignments Conversation[] @relation("ConversationAssignee")
  comments    InstagramComment[] @relation("CommentAssignee")
  notes       Note[]
  auditLogs   AuditLog[]
}

model Membership {
  tenantId String @db.Uuid
  userId   String @db.Uuid
  role     Role   @default(AGENT)
  status   MembershipStatus @default(ACTIVE)
  availability Availability @default(OFFLINE)
  capacity Int @default(5)
  joinedAt DateTime?
  invitedAt DateTime?
  lastActiveAt DateTime?
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([tenantId, userId])
  @@index([userId])
}

model ChannelConnection {
  id                    String           @id @default(uuid()) @db.Uuid
  tenantId              String           @db.Uuid
  provider              Provider
  status                ConnectionStatus @default(PENDING)
  displayName           String
  externalAccountId     String?
  encryptedAccessToken  String?
  encryptedRefreshToken String?
  tokenExpiresAt        DateTime?
  metadata              Json             @default("{}")
  lastSyncedAt          DateTime?
  lastError             String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  tenant                Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  identities            ExternalIdentity[]
  conversations         Conversation[]
  posts                 InstagramPost[]
  syncCursors           SyncCursor[]
  webhookEvents         WebhookEvent[]
  outboundJobs          OutboundJob[]

  @@unique([tenantId, provider, externalAccountId])
  @@index([tenantId, provider, status])
}

model Contact {
  id              String             @id @default(uuid()) @db.Uuid
  tenantId        String             @db.Uuid
  displayName     String
  primaryEmail    String?
  primaryPhone    String?
  avatarUrl       String?
  customFields    Json               @default("{}")
  mergedIntoId    String?            @db.Uuid
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mergedInto      Contact?           @relation("ContactMergeTarget", fields: [mergedIntoId], references: [id])
  mergedContacts  Contact[]          @relation("ContactMergeTarget")
  identities      ExternalIdentity[]
  conversations   Conversation[]
  comments        InstagramComment[]
  notes           Note[]
  labels          ContactLabel[]
  sourceMerges    ContactMerge[]     @relation("MergeSource")
  targetMerges    ContactMerge[]     @relation("MergeTarget")

  @@index([tenantId, displayName])
  @@index([tenantId, primaryEmail])
  @@index([tenantId, primaryPhone])
}

model ExternalIdentity {
  id           String            @id @default(uuid()) @db.Uuid
  tenantId     String            @db.Uuid
  connectionId String?           @db.Uuid
  contactId    String?           @db.Uuid
  provider     Provider
  externalId   String
  address      String?
  displayName  String?
  avatarUrl    String?
  verified     Boolean           @default(false)
  metadata     Json              @default("{}")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connection   ChannelConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  contact      Contact?          @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([tenantId, provider, externalId])
  @@index([tenantId, address])
  @@index([contactId])
}

model Conversation {
  id                     String              @id @default(uuid()) @db.Uuid
  tenantId               String              @db.Uuid
  connectionId           String              @db.Uuid
  contactId              String?             @db.Uuid
  externalId             String
  channel                Provider
  subject                String?
  status                 ConversationStatus  @default(OPEN)
  assigneeId             String?             @db.Uuid
  unreadCount            Int                 @default(0)
  lastMessageAt          DateTime
  lastInboundAt          DateTime?
  serviceWindowExpiresAt DateTime?
  metadata               Json                @default("{}")
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  tenant                 Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connection             ChannelConnection   @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  contact                Contact?            @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignee               User?               @relation("ConversationAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  messages               Message[]
  labels                 ConversationLabel[]
  outboundJobs           OutboundJob[]

  @@unique([tenantId, connectionId, externalId])
  @@index([tenantId, status, lastMessageAt(sort: Desc)])
  @@index([tenantId, channel, lastMessageAt(sort: Desc)])
  @@index([assigneeId])
}

model Message {
  id                String           @id @default(uuid()) @db.Uuid
  tenantId          String           @db.Uuid
  conversationId    String           @db.Uuid
  externalId        String
  providerEventId   String?
  direction         MessageDirection
  deliveryStatus    DeliveryStatus
  senderExternalId  String?
  subject           String?
  text              String?
  sanitizedHtml     String?
  replyToExternalId String?
  sentAt            DateTime
  rawPayload         Json?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation      Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  attachments       Attachment[]

  @@unique([tenantId, conversationId, externalId])
  @@index([tenantId, sentAt(sort: Desc)])
  @@index([conversationId, sentAt])
}

model Attachment {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  messageId     String?  @db.Uuid
  externalId    String?
  fileName      String?
  mimeType      String
  sizeBytes     Int?
  storageKey    String?
  providerUrl   String?
  scanStatus    String   @default("PENDING")
  createdAt     DateTime @default(now())
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  message       Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([tenantId, messageId])
}

model InstagramPost {
  id           String            @id @default(uuid()) @db.Uuid
  tenantId     String            @db.Uuid
  connectionId String            @db.Uuid
  externalId   String
  caption      String?
  permalink    String?
  mediaUrl     String?
  publishedAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connection   ChannelConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  comments     InstagramComment[]

  @@unique([tenantId, connectionId, externalId])
}

model InstagramComment {
  id                String         @id @default(uuid()) @db.Uuid
  tenantId          String         @db.Uuid
  postId            String         @db.Uuid
  contactId         String?        @db.Uuid
  externalId        String
  parentExternalId  String?
  authorExternalId  String
  authorName        String?
  text              String
  status            CommentStatus  @default(OPEN)
  assigneeId        String?        @db.Uuid
  isHidden          Boolean        @default(false)
  commentedAt       DateTime
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  post              InstagramPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  contact           Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignee          User?          @relation("CommentAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@unique([tenantId, externalId])
  @@index([tenantId, status, commentedAt(sort: Desc)])
}

model Label {
  id            String              @id @default(uuid()) @db.Uuid
  tenantId      String              @db.Uuid
  name          String
  color         String
  createdAt     DateTime            @default(now())
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations ConversationLabel[]
  contacts      ContactLabel[]

  @@unique([tenantId, name])
}

model ConversationLabel {
  tenantId       String       @db.Uuid
  conversationId String       @db.Uuid
  labelId        String       @db.Uuid
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  label          Label        @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([conversationId, labelId])
  @@index([tenantId])
}

model ContactLabel {
  tenantId  String  @db.Uuid
  contactId String  @db.Uuid
  labelId   String  @db.Uuid
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  label     Label   @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([contactId, labelId])
  @@index([tenantId])
}

model Note {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  contactId String   @db.Uuid
  authorId  String   @db.Uuid
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([tenantId, contactId, createdAt(sort: Desc)])
}

model SavedView {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  name      String
  query     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
}

model SyncCursor {
  id           String            @id @default(uuid()) @db.Uuid
  tenantId     String            @db.Uuid
  connectionId String            @db.Uuid
  resource     String
  cursor       String?
  expiresAt    DateTime?
  lastSyncedAt DateTime?
  metadata     Json              @default("{}")
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connection   ChannelConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, resource])
  @@index([tenantId, expiresAt])
}

model WebhookEvent {
  id              String            @id @default(uuid()) @db.Uuid
  tenantId        String            @db.Uuid
  connectionId    String?           @db.Uuid
  provider        Provider
  externalEventId String
  payload         Json
  status          JobStatus         @default(PENDING)
  attempts        Int               @default(0)
  error           String?
  receivedAt      DateTime          @default(now())
  processedAt     DateTime?
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connection      ChannelConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@unique([tenantId, provider, externalEventId])
  @@index([tenantId, status, receivedAt])
}

model OutboundJob {
  id                  String           @id @default(uuid()) @db.Uuid
  tenantId            String           @db.Uuid
  connectionId        String           @db.Uuid
  conversationId      String           @db.Uuid
  idempotencyKey      String
  payload             Json
  status              JobStatus        @default(PENDING)
  externalMessageId   String?
  attempts            Int              @default(0)
  nextAttemptAt       DateTime?
  error               String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  tenant              Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connection          ChannelConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  conversation        Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([tenantId, idempotencyKey])
  @@index([status, nextAttemptAt])
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  actorId    String?  @db.Uuid
  action     String
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt(sort: Desc)])
}

model ContactMerge {
  id              String      @id @default(uuid()) @db.Uuid
  tenantId        String      @db.Uuid
  sourceContactId String      @db.Uuid
  targetContactId String      @db.Uuid
  status          MergeStatus
  score           Float?
  reason          String?
  snapshot        Json?
  createdAt       DateTime    @default(now())
  confirmedAt     DateTime?
  undoneAt        DateTime?
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sourceContact   Contact     @relation("MergeSource", fields: [sourceContactId], references: [id], onDelete: Restrict)
  targetContact   Contact     @relation("MergeTarget", fields: [targetContactId], references: [id], onDelete: Restrict)

  @@index([tenantId, status, createdAt(sort: Desc)])
}
